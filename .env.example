# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_creative

# --- LLM ---
# mock = 无需 API key，返回预设文本（开发/测试用）
# openai / deepseek / siliconflow = 需要配置 API key
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# --- RAG / Embedding ---
# mock = 基于哈希的伪向量（开发/测试用）
# openai = 需要 EMBEDDING_API_KEY
EMBEDDING_PROVIDER=mock
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- LangGraph ---
# true = 使用 PostgreSQL 持久化 checkpoint
LANGGRAPH_CHECKPOINT_DB=false

# --- 应用 ---
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_BYTES=5242880
MAX_TXT_IMPORT_BYTES=52428800
